# ground-station/.env — operator backend config. Copy to .env and fill MENDER_TOKEN.
# (.env is gitignored; never commit a token.)

# A Mender Personal Access Token (mint in the Mender UI → Settings → API tokens,
# or via the useradm API). Required by gs-api.
MENDER_TOKEN=

# The Mender GW Management API. Default = the server DNS name on the mender network
# (mender/server/up.sh's gateway). Override to a reachable URL when running gs-api
# outside the GW compose (e.g. https://10.0.0.99).
MENDER_SERVER=https://mender-api-gateway
MENDER_INSECURE=1            # the bundled GW is self-signed (dev)
MENDER_FLAVOR=oss           # oss | hosted

# The MinIO distribution planes (the gs-minio service).
S3_ENDPOINT=http://gs-minio:9000
MINIO_USER=theia
MINIO_PASSWORD=theiaminio

# Where the web UI is exposed on the host.
GS_WEB_PORT=8088
